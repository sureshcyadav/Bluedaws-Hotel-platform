# ── Server ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── PostgreSQL (Render provides this as one URL) ─────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/bluedaws_hotel

# ── CORS (comma-separated list of allowed frontend origins) ──────────────
ALLOWED_ORIGINS=https://sureshcyadav.github.io,http://localhost:5500

# ── Admin portal password (set a strong random string) ───────────────────
ADMIN_PASSWORD=change_me_to_something_long_and_random

# ── JWT signing secret (SEPARATE from ADMIN_PASSWORD — 32+ random chars) ─
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string_of_at_least_32_characters

# ── Gmail SMTP (for booking confirmation and enquiry emails) ──────────────
# GMAIL_USER    : the Gmail address emails are sent from
# GMAIL_APP_PASSWORD : a Gmail App Password (NOT your account password)
#   To generate: myaccount.google.com → Security → 2-Step Verification → App passwords
#   Enter the 16-char code with NO spaces (e.g. tepmdbxogmolrgrw)
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=your16charapppassword
